# TanStack Start reads both client and server env from the repository root (`../.env`).
# Keep public VITE_* values there, alongside the Appwrite server variables used for auth.
VITE_COMETCHAT_APP_ID=YOUR_COMETCHAT_APP_ID
VITE_COMETCHAT_REGION=YOUR_COMETCHAT_REGION
VITE_COMETCHAT_AUTH_KEY=YOUR_COMETCHAT_AUTH_KEY
VITE_COMETCHAT_FACULTY_UID=YOUR_FACULTY_COMETCHAT_UID
VITE_COMETCHAT_PANELIST_UID=YOUR_PANELIST_COMETCHAT_UID


APPWRITE_ENDPOINT=https://your-appwrite-endpoint/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-api-key
APPWRITE_DATABASE_ID=your-appwrite-database-id
APPWRITE_ACCOUNTS_TABLE_ID=accounts
APPWRITE_DOCUMENT_TRACKING_TABLE_ID=document_tracking
APPWRITE_AUTH_RECOVERY_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
AUTH_COOKIE_NAME=fsme_session
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
LOG_SERVER_REQUESTS=true
